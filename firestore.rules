rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default: deny everything not explicitly allowed.
    match /{document=**} {
      allow read, write: if false;
    }

    // users/{userId} — each user can read and write only their own document.
    // Cloud Functions use the Admin SDK and bypass these rules entirely.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // notification_logs — Cloud Functions write-only via Admin SDK.
    // No client access permitted.
    match /notification_logs/{logId} {
      allow read, write: if false;
    }
  }
}
